# 104 企業帳號
ACCOUNT_104_USERNAME=your_104_username
ACCOUNT_104_PASSWORD=your_104_password

# LinkedIn (預留)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Scorecard 門檻分數
SCORECARD_THRESHOLD=70.0

# 資料庫
DATABASE_URL=sqlite:///./candidates.db

# Telegram 通知設定（搜尋完成後自動推送結果）
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# 排程設定（留空表示停用內建排程，改用 API 或 GitHub Actions 手動觸發）
# SCHEDULE_CRON_HOUR=8
# SCHEDULE_CRON_MINUTE=0
# SCHEDULE_TIMEZONE=Asia/Taipei

# Cookie 儲存路徑（用於 104 登入狀態持久化）
COOKIE_STORAGE_PATH=/tmp/104_session
